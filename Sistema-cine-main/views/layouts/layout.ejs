<!-- views/layouts/layout.ejs -->
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Sistema de Cine</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <% const navActive = typeof active !== 'undefined' ? active : ''; %>
    <% const role = currentUser ? currentUser.role : null; %>
    <div class="container">
        <header>
            <div class="logo">
                <i class="fas fa-film"></i>
                <div>
                    <h1>CineManager</h1>
                    <p>Sistema de Gestión de Cines</p>
                </div>
            </div>
            <nav>
                <ul>
                    <li>
                        <a href="/" class="<%= navActive === 'inicio' ? 'active' : '' %>">
                            <i class="fas fa-home"></i>
                            Inicio
                        </a>
                    </li>
                    <li>
                        <a href="/peliculas" class="<%= navActive === 'peliculas' ? 'active' : '' %>">
                            <i class="fas fa-video"></i>
                            Películas
                        </a>
                    </li>
                    <% if (role !== 'seller') { %>
                        <li>
                            <a href="/salas" class="<%= navActive === 'salas' ? 'active' : '' %>">
                                <i class="fas fa-door-open"></i>
                                Salas
                            </a>
                        </li>
                        <li>
                            <a href="/productos" class="<%= navActive === 'productos' ? 'active' : '' %>">
                                <i class="fas fa-box-open"></i>
                                Comida
                            </a>
                        </li>
                        <li>
                            <a href="/funciones" class="<%= navActive === 'funciones' ? 'active' : '' %>">
                                <i class="fas fa-calendar-alt"></i>
                                Funciones
                            </a>
                        </li>
                    <% } %>
                    <% if (role === 'admin') { %>
                        <li>
                            <a href="/entradas" class="<%= navActive === 'entradas' ? 'active' : '' %>">
                                <i class="fas fa-ticket-alt"></i>
                                Entradas
                            </a>
                        </li>
                        <li>
                            <a href="/ventas" class="<%= navActive === 'ventas' ? 'active' : '' %>">
                                <i class="fas fa-cash-register"></i>
                                Ventas
                            </a>
                        </li>
                        <li>
                            <a href="/clientes" class="<%= navActive === 'clientes' ? 'active' : '' %>">
                                <i class="fas fa-users"></i>
                                Clientes
                            </a>
                        </li>
                        <li>
                            <a href="/auth/sellers" class="<%= navActive === 'vendedores' ? 'active' : '' %>">
                                <i class="fas fa-user-tie"></i>
                                Vendedores
                            </a>
                        </li>
                    <% } else if (role === 'seller') { %>
                        <li>
                            <a href="/ventas" class="<%= navActive === 'ventas' ? 'active' : '' %>">
                                <i class="fas fa-cash-register"></i>
                                Ventas
                            </a>
                        </li>
                    <% } else if (currentUser) { %>
                        <li>
                            <a href="/ventas/rapida" class="<%= navActive === 'ventas' ? 'active' : '' %>">
                                <i class="fas fa-shopping-cart"></i>
                                Comprar
                            </a>
                        </li>
                    <% } %>
                    <% if (!currentUser) { %>
                        <li>
                            <a href="/auth/login" class="<%= navActive === 'auth' ? 'active' : '' %>">
                                <i class="fas fa-sign-in-alt"></i>
                                Login
                            </a>
                        </li>
                        <li>
                            <a href="/auth/register" class="<%= navActive === 'auth' ? 'active' : '' %>">
                                <i class="fas fa-user-plus"></i>
                                Registro
                            </a>
                        </li>
                    <% } %>
                </ul>
            </nav>
            <% if (currentUser) { %>
                <div style="display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap;margin-top:12px;">
                    <small>
                        Sesión: <strong><%= currentUser.nombre %></strong>
                        (<%= currentUser.role === 'admin' ? 'ADMIN' : (currentUser.role === 'seller' ? 'VENDEDOR' : 'CLIENTE') %>)
                    </small>
                    <form action="/auth/logout" method="POST">
                        <button type="submit" class="btn btn-danger" style="padding:8px 16px;">
                            <i class="fas fa-sign-out-alt"></i>
                            Salir
                        </button>
                    </form>
                </div>
            <% } %>
        </header>

        <main class="fade-in">
            <% if (success_msg) { %>
                <div class="alert alert-success">
                    <i class="fas fa-check-circle"></i>
                    <span><%= success_msg %></span>
                </div>
            <% } %>
            
            <% if (error_msg) { %>
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-circle"></i>
                    <span><%= error_msg %></span>
                </div>
            <% } %>

            <%- body %>
        </main>

        <footer>
            <p>
                <i class="fas fa-copyright"></i>
                2026 Sistema de Gestión de Cine | Métodos HTTP: GET, POST, PUT, DELETE
            </p>
        </footer>
    </div>
</body>
</html>
