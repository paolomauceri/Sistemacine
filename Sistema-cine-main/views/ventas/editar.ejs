<div class="form-container">
    <div class="form-title">
        <h2><i class="fas fa-edit"></i> Editar Venta</h2>
        <p>Actualiza el comprobante de venta</p>
    </div>

    <form action="/ventas/<%= venta.id %>?_method=PUT" method="POST">
        <div class="form-group">
            <label for="entrada_id"><i class="fas fa-ticket-alt"></i> Entrada</label>
            <select id="entrada_id" name="entrada_id" class="form-control" required>
                <% entradas.forEach(e => { %>
                    <option value="<%= e.id %>" <%= String(venta.entrada_id) === String(e.id) ? 'selected' : '' %>>#<%= e.id %> - <%= e.titulo %> - $<%= Number(e.total).toFixed(2) %></option>
                <% }) %>
            </select>
        </div>

        <div class="form-group">
            <label for="descripcion"><i class="fas fa-align-left"></i> Descripcion</label>
            <textarea id="descripcion" name="descripcion" class="form-control"><%= venta.descripcion || '' %></textarea>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label for="subtotal"><i class="fas fa-dollar-sign"></i> Subtotal</label>
                <input type="number" step="0.01" min="0.01" id="subtotal" name="subtotal" class="form-control" required value="<%= venta.subtotal %>">
            </div>
            <div class="form-group">
                <label for="descuento"><i class="fas fa-percentage"></i> Descuento</label>
                <input type="number" step="0.01" min="0" id="descuento" name="descuento" class="form-control" value="<%= venta.descuento %>">
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label for="impuesto"><i class="fas fa-file-invoice-dollar"></i> Impuesto</label>
                <input type="number" step="0.01" min="0" id="impuesto" name="impuesto" class="form-control" value="<%= venta.impuesto %>">
            </div>
            <div class="form-group">
                <label for="total"><i class="fas fa-receipt"></i> Total</label>
                <input type="number" step="0.01" min="0.01" id="total" name="total" class="form-control" required value="<%= venta.total %>">
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label for="metodo_pago"><i class="fas fa-credit-card"></i> Metodo de pago</label>
                <select id="metodo_pago" name="metodo_pago" class="form-control" required>
                    <option value="EFECTIVO" <%= venta.metodo_pago === 'EFECTIVO' ? 'selected' : '' %>>EFECTIVO</option>
                    <option value="TARJETA" <%= venta.metodo_pago === 'TARJETA' ? 'selected' : '' %>>TARJETA</option>
                    <option value="TRANSFERENCIA" <%= venta.metodo_pago === 'TRANSFERENCIA' ? 'selected' : '' %>>TRANSFERENCIA</option>
                </select>
            </div>
            <div class="form-group">
                <label for="estado"><i class="fas fa-check-circle"></i> Estado</label>
                <select id="estado" name="estado" class="form-control" required>
                    <option value="CONFIRMADA" <%= venta.estado === 'CONFIRMADA' ? 'selected' : '' %>>CONFIRMADA</option>
                    <option value="ANULADA" <%= venta.estado === 'ANULADA' ? 'selected' : '' %>>ANULADA</option>
                </select>
            </div>
        </div>

        <% if (error_msg) { %><div class="alert alert-danger"><i class="fas fa-exclamation-circle"></i><%= error_msg %></div><% } %>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Actualizar</button>
            <a href="/ventas" class="btn btn-warning"><i class="fas fa-times"></i> Cancelar</a>
        </div>
    </form>
</div>
