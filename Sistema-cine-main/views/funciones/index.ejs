<div class="header-actions">
    <h2><i class="fas fa-calendar-alt"></i> Funciones</h2>
    <% if (currentUser && currentUser.role === 'admin') { %>
        <a href="/funciones/nueva" class="btn btn-primary">
            <i class="fas fa-plus-circle"></i>
            Nueva Funcion
        </a>
    <% } %>
</div>

<div class="method-badge">
    <span class="badge get">GET</span>
    <span class="badge post">POST</span>
    <span class="badge put">PUT</span>
    <span class="badge delete">DELETE</span>
</div>

<% if (funciones.length === 0) { %>
    <div class="alert alert-info"><i class="fas fa-info-circle"></i> No hay funciones registradas.</div>
<% } else { %>
    <div class="data-grid">
        <% funciones.forEach(funcion => { %>
            <div class="card">
                <div class="card-header">
                    <h3><%= funcion.pelicula_titulo %></h3>
                    <span class="card-badge">ID: <%= funcion.id %></span>
                </div>
                <div class="card-body">
                    <p><i class="fas fa-door-open"></i><strong>Sala:</strong> <%= funcion.sala_nombre %></p>
                    <p><i class="fas fa-calendar"></i><strong>Fecha:</strong> <%= funcion.fecha %></p>
                    <p><i class="fas fa-clock"></i><strong>Hora:</strong> <%= funcion.hora %></p>
                    <p><i class="fas fa-dollar-sign"></i><strong>Precio base:</strong> $<%= Number(funcion.precio_base).toFixed(2) %></p>
                    <p><i class="fas fa-check-circle"></i><strong>Estado:</strong> <%= funcion.estado %></p>
                </div>
                <div class="card-footer">
                    <% if (currentUser && currentUser.role === 'admin') { %>
                        <a href="/funciones/<%= funcion.id %>/editar" class="btn btn-warning"><i class="fas fa-edit"></i> Editar</a>
                        <form action="/funciones/<%= funcion.id %>?_method=DELETE" method="POST" style="flex:1;">
                            <button type="submit" class="btn btn-danger" onclick="return confirm('¿Eliminar esta funcion?')"><i class="fas fa-trash"></i> Eliminar</button>
                        </form>
                    <% } else { %>
                        <a href="/ventas/rapida?funcion_id=<%= funcion.id %>" class="btn btn-success"><i class="fas fa-shopping-cart"></i> Comprar</a>
                    <% } %>
                </div>
            </div>
        <% }) %>
    </div>
<% } %>
