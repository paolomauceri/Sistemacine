<div class="form-container">
    <div class="form-title">
        <h2><i class="fas fa-edit"></i> Editar Funcion</h2>
        <p>Actualiza la programacion de la funcion</p>
    </div>

    <form action="/funciones/<%= funcion.id %>?_method=PUT" method="POST">
        <div class="form-row">
            <div class="form-group">
                <label for="pelicula_id"><i class="fas fa-film"></i> Pelicula</label>
                <select id="pelicula_id" name="pelicula_id" class="form-control" required>
                    <% peliculas.forEach(p => { %>
                        <option value="<%= p.id %>" <%= String(funcion.pelicula_id) === String(p.id) ? 'selected' : '' %>><%= p.titulo %></option>
                    <% }) %>
                </select>
            </div>
            <div class="form-group">
                <label for="sala_id"><i class="fas fa-door-open"></i> Sala</label>
                <select id="sala_id" name="sala_id" class="form-control" required>
                    <% salas.forEach(s => { %>
                        <option value="<%= s.id %>" <%= String(funcion.sala_id) === String(s.id) ? 'selected' : '' %>><%= s.nombre %></option>
                    <% }) %>
                </select>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label for="fecha"><i class="fas fa-calendar"></i> Fecha</label>
                <input type="date" id="fecha" name="fecha" class="form-control" required value="<%= funcion.fecha %>">
            </div>
            <div class="form-group">
                <label for="hora"><i class="fas fa-clock"></i> Hora</label>
                <input type="time" id="hora" name="hora" class="form-control" required value="<%= funcion.hora %>">
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label for="precio_base"><i class="fas fa-dollar-sign"></i> Precio base</label>
                <input type="number" step="0.01" min="0.01" id="precio_base" name="precio_base" class="form-control" required value="<%= funcion.precio_base %>">
            </div>
            <div class="form-group">
                <label for="estado"><i class="fas fa-check-circle"></i> Estado</label>
                <select id="estado" name="estado" class="form-control" required>
                    <option value="PROGRAMADA" <%= funcion.estado === 'PROGRAMADA' ? 'selected' : '' %>>PROGRAMADA</option>
                    <option value="CANCELADA" <%= funcion.estado === 'CANCELADA' ? 'selected' : '' %>>CANCELADA</option>
                    <option value="AGOTADA" <%= funcion.estado === 'AGOTADA' ? 'selected' : '' %>>AGOTADA</option>
                </select>
            </div>
        </div>

        <% if (error_msg) { %><div class="alert alert-danger"><i class="fas fa-exclamation-circle"></i><%= error_msg %></div><% } %>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Actualizar</button>
            <a href="/funciones" class="btn btn-warning"><i class="fas fa-times"></i> Cancelar</a>
        </div>
    </form>
</div>
