<div class="header-actions">
    <h2><i class="fas fa-box-open"></i> Productos</h2>
    <% if (currentUser && currentUser.role === 'admin') { %>
        <a href="/productos/nueva" class="btn btn-primary">
            <i class="fas fa-plus-circle"></i>
            Nuevo Producto
        </a>
    <% } %>
</div>

<div class="method-badge">
    <span class="badge get">GET</span>
    <span class="badge post">POST</span>
    <span class="badge put">PUT</span>
    <span class="badge delete">DELETE</span>
</div>

<% if (productos.length === 0) { %>
    <div class="alert alert-info">
        <i class="fas fa-info-circle"></i>
        No hay productos registrados.
    </div>
<% } else { %>
    <div class="data-grid">
        <% productos.forEach(producto => { %>
            <div class="card">
                <div class="card-header">
                    <h3><%= producto.nombre %></h3>
                    <span class="card-badge">ID: <%= producto.id %></span>
                </div>
                <div class="card-body">
                    <p><i class="fas fa-tag"></i><strong>Tipo:</strong> <%= producto.tipo %></p>
                    <p><i class="fas fa-dollar-sign"></i><strong>Precio:</strong> $<%= Number(producto.precio).toFixed(2) %></p>
                    <p><i class="fas fa-boxes"></i><strong>Stock:</strong> <%= producto.stock %></p>
                </div>
                <div class="card-footer">
                    <% if (currentUser && currentUser.role === 'admin') { %>
                        <a href="/productos/<%= producto.id %>/editar" class="btn btn-warning">
                            <i class="fas fa-edit"></i>
                            Editar
                        </a>
                        <form action="/productos/<%= producto.id %>?_method=DELETE" method="POST" style="flex:1;">
                            <button type="submit" class="btn btn-danger" onclick="return confirm('¿Eliminar este producto?')">
                                <i class="fas fa-trash"></i>
                                Eliminar
                            </button>
                        </form>
                    <% } else { %>
                        <form action="/productos/<%= producto.id %>/comprar" method="POST" style="display:flex;gap:10px;align-items:center;flex:1;">
                            <input type="number" name="cantidad" min="1" max="<%= producto.stock %>" value="1" class="form-control" style="max-width:100px;">
                            <button type="submit" class="btn btn-success">
                                <i class="fas fa-shopping-cart"></i>
                                Comprar
                            </button>
                        </form>
                    <% } %>
                </div>
            </div>
        <% }) %>
    </div>
<% } %>
