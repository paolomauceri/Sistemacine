<div class="form-container">
    <div class="form-title">
        <h2><i class="fas fa-edit"></i> Editar Producto</h2>
        <p>Actualiza los datos del producto</p>
    </div>

    <form action="/productos/<%= producto.id %>?_method=PUT" method="POST">
        <div class="form-group">
            <label for="nombre"><i class="fas fa-heading"></i> Nombre</label>
            <input type="text" id="nombre" name="nombre" class="form-control" required value="<%= producto.nombre %>">
        </div>

        <div class="form-row">
            <div class="form-group">
                <label for="tipo"><i class="fas fa-tag"></i> Tipo</label>
                <select id="tipo" name="tipo" class="form-control" required>
                    <option value="Snack" <%= producto.tipo === 'Snack' ? 'selected' : '' %>>Snack</option>
                    <option value="Bebida" <%= producto.tipo === 'Bebida' ? 'selected' : '' %>>Bebida</option>
                    <option value="Combo" <%= producto.tipo === 'Combo' ? 'selected' : '' %>>Combo</option>
                    <option value="Merch" <%= producto.tipo === 'Merch' ? 'selected' : '' %>>Merch</option>
                </select>
            </div>
            <div class="form-group">
                <label for="precio"><i class="fas fa-dollar-sign"></i> Precio</label>
                <input type="number" step="0.01" min="0.01" id="precio" name="precio" class="form-control" required value="<%= producto.precio %>">
            </div>
        </div>

        <div class="form-group">
            <label for="stock"><i class="fas fa-boxes"></i> Stock</label>
            <input type="number" min="0" id="stock" name="stock" class="form-control" required value="<%= producto.stock %>">
        </div>

        <% if (error_msg) { %>
            <div class="alert alert-danger">
                <i class="fas fa-exclamation-circle"></i>
                <%= error_msg %>
            </div>
        <% } %>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Actualizar</button>
            <a href="/productos" class="btn btn-warning"><i class="fas fa-times"></i> Cancelar</a>
        </div>
    </form>
</div>
