<div class="header-actions">
    <h2><i class="fas fa-ticket-alt"></i> Entradas</h2>
    <a href="/entradas/nueva" class="btn btn-primary"><i class="fas fa-plus-circle"></i> Nueva Entrada</a>
</div>

<div class="method-badge">
    <span class="badge get">GET</span>
    <span class="badge post">POST</span>
    <span class="badge put">PUT</span>
    <span class="badge delete">DELETE</span>
</div>

<% if (entradas.length === 0) { %>
    <div class="alert alert-info"><i class="fas fa-info-circle"></i> No hay entradas registradas.</div>
<% } else { %>
    <div class="data-grid">
        <% entradas.forEach(entrada => { %>
            <div class="card">
                <div class="card-header">
                    <h3><%= entrada.pelicula_titulo %></h3>
                    <span class="card-badge">ID: <%= entrada.id %></span>
                </div>
                <div class="card-body">
                    <p><i class="fas fa-calendar"></i><strong>Funcion:</strong> <%= entrada.fecha %> <%= entrada.hora %></p>
                    <p><i class="fas fa-user"></i><strong>Cliente:</strong> <%= entrada.cliente_nombre || 'Publico general' %></p>
                    <p><i class="fas fa-users"></i><strong>Cantidad:</strong> <%= entrada.cantidad %></p>
                    <p><i class="fas fa-couch"></i><strong>Asientos:</strong> <%= entrada.asientos || 'Sin asignar' %></p>
                    <p><i class="fas fa-dollar-sign"></i><strong>Total:</strong> $<%= Number(entrada.total).toFixed(2) %></p>
                </div>
                <div class="card-footer">
                    <a href="/entradas/<%= entrada.id %>/editar" class="btn btn-warning"><i class="fas fa-edit"></i> Editar</a>
                    <form action="/entradas/<%= entrada.id %>?_method=DELETE" method="POST" style="flex:1;">
                        <button type="submit" class="btn btn-danger" onclick="return confirm('¿Eliminar esta entrada?')"><i class="fas fa-trash"></i> Eliminar</button>
                    </form>
                </div>
            </div>
        <% }) %>
    </div>
<% } %>
